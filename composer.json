{
  "name": "codekinz/laravel-palette",
  "description": "Extract dominant colors from images in Laravel.",
  "keywords": [
    "laravel",
    "color",
    "palette",
    "image",
    "extract",
    "dominant color"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Codekinz"
    }
  ],
  "require": {
    "php": "^8.1",
    "league/color-extractor": "^0.4",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "laravel/pint": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Codekinz\\LaravelPalette\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Codekinz\\LaravelPalette\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Codekinz\\LaravelPalette\\PaletteServiceProvider"
      ],
      "aliases": {
        "Palette": "Codekinz\\LaravelPalette\\Facades\\Palette"
      }
    }
  },
  "scripts": {
    "format": "vendor/bin/pint",
    "test": "vendor/bin/pest"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
